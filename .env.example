EVOLUTION_BASE_URL=http://127.0.0.1:8080
EVOLUTION_API_KEY=replace-me
EVOLUTION_INSTANCE=replace-instance-name
GATEIO_API_KEY=
GATEIO_API_SECRET=

# WhatsApp group JID format usually ends with @g.us
WHATSAPP_GROUP_JID=1234567890-1234567890@g.us
MESSAGE_TEXT=Daily automated message

# Optional: override endpoint template for your Evolution API version.
# Available placeholders: {instance}
SEND_ENDPOINT_TEMPLATE=/message/sendText/{instance}

# Sender behavior
MAX_RETRIES=5
RETRY_BASE_SECONDS=2
REQUEST_TIMEOUT_SECONDS=15

# Local state/log paths
STATE_DIR=./state
LOG_FILE=./state/sender.log

TELEGRAM_BOT_TOKEN=replace-telegram-bot-token
TELEGRAM_CHAT_ID=replace-telegram-chat-id
